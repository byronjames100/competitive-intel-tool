# IRONSCOUT Phase 2 Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Anthropic API Key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# SQLite database path (relative to project root)
DATABASE_URL=./ironscout.db

# Server port
PORT=3000

# Your deployed frontend URL (for CORS)
# During development, use: http://localhost:3000
CLIENT_URL=https://your-domain.com

# Environment
NODE_ENV=production
